# Copy to .env and adjust. All values are optional in development.

# Generate one for production, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=change-me-in-production

DEBUG=True

# Comma-separated. Required when DEBUG=False.
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated origins (with scheme) trusted for CSRF on unsafe requests.
# Required once you serve over HTTPS behind nginx.
# CSRF_TRUSTED_ORIGINS=https://app.poseidon-klimaanpassung.de

# Turn on HTTPS hardening (SSL redirect, secure cookies, HSTS).
# Enable ONLY after TLS/certbot is in place, else HTTP access loops on redirect.
# HTTPS=True

# Defaults to local SQLite. To use Postgres:
#   1) uv add "psycopg[binary]"
#   2) uncomment and set:
# DATABASE_URL=postgres://user:password@localhost:5432/catalogue
